# Entorno virtual (cada participante crea el suyo con: python -m venv .venv)
.venv/
venv/
env/

# Cache de Python
__pycache__/
*.pyc

# Checkpoints de Jupyter
.ipynb_checkpoints/

# Configuración de editores / SO
